# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — powers Sonnet (agent loop), Haiku (extraction), Opus (self-observability advisory)
ANTHROPIC_API_KEY=

# Stable Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# A random fallback would silently invalidate all sessions on every restart.
SECRET_KEY=

# ── Required for full functionality ───────────────────────────────────────────

# Exa.ai — IOC search, CVE news monitoring, learning recommendations, package intel
EXA_API_KEY=

# ── Optional — features degrade gracefully when absent ────────────────────────

# Groq — grounded verification pass (GV) after Sonnet drafts a reply. Skipped silently if absent.
GROQ_API_KEY=
# GROQ_MODEL=openai/gpt-oss-120b  # default

# VirusTotal — hash IOC enrichment in War Room. Button disabled if absent.
VIRUSTOTAL_API_KEY=

# Socket.dev — supply-chain behavioral risk scores. Skipped if absent.
SOCKET_API_KEY=

# Cisco PSIRT — vendor advisories for Cisco CVEs. Disabled if either key is absent.
CISCO_API_KEY=
CISCO_CLIENT_SECRET=

# SMTP — 2FA and password-reset codes. Without this, codes are printed to the console/logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=   # defaults to SMTP_USER if omitted

# ── Local dev only ────────────────────────────────────────────────────────────

# Required for local HTTP (cookies are HTTPS-only by default). Do not set on Fly.io.
SECURE_COOKIES=0

# Logging verbosity: DEBUG (verbose, tool call detail) or INFO (default).
# Leave unset on Fly.io — defaults to INFO.
LOG_LEVEL=DEBUG

# ── Advanced ──────────────────────────────────────────────────────────────────

# SQLite file path. Defaults to smashedburger.db in the project directory.
# On Fly.io this is set to /data/smashedburger.db via fly.toml.
# DB_PATH=/data/smashedburger.db

# Comma-separated list of source module names to load. All sources loaded by default.
# ENABLED_SOURCES=nvd,euvd,kev,exploitdb

# Groq model override.
# GROQ_MODEL=openai/gpt-oss-120b
